--- !u!114 &2079923148
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2079923147}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9f64ff45bd52b63489bbae7d7d579685, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CutsceneController
  panels:
  - panelName: Praca - dormindo
    sceneRoot: {fileID: 2132808114}
    lines:
    - speakerName: 
      text: "Outubro. D\xE9cima noite no banco da pra\xE7a."
      portraitColor: {r: 0.85, g: 0.85, b: 0.85, a: 1}
      blipPitch: 1
    - speakerName: 
      text: "Para a chuva, mas s\xF3 por uns minutos."
      portraitColor: {r: 0.85, g: 0.85, b: 0.85, a: 1}
      blipPitch: 1
    fadeWhiteOut: 0
  - panelName: Praca - acorda
    sceneRoot: {fileID: 693097686}
    lines:
    - speakerName: Woody
      text: "...que barulho \xE9 esse."
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    - speakerName: Woody
      text: "Isso n\xE3o estava aqui ontem."
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    fadeWhiteOut: 0
  - panelName: Cabine
    sceneRoot: {fileID: 586896885}
    lines:
    - speakerName: Woody
      text: "...t\xF4 t\xE3o mal assim?"
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    - speakerName: Woody
      text: "J\xE1 que cheguei at\xE9 aqui."
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    fadeWhiteOut: 1
  - panelName: Flash
    sceneRoot: {fileID: 2117694062}
    lines:
    - speakerName: 
      text: ...
      portraitColor: {r: 0.85, g: 0.85, b: 0.85, a: 1}
      blipPitch: 1
    fadeWhiteOut: 0
  - panelName: "Aliens - apresenta\xE7\xE3o"
    sceneRoot: {fileID: 1425033508}
    lines:
    - speakerName: ???
      text: "Ol\xE1, Woody. Te observamos por anos."
      portraitColor: {r: 0.4, g: 0.9, b: 0.95, a: 1}
      blipPitch: 1.45
    - speakerName: Woody
      text: Cobaia?
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    - speakerName: ???
      text: Candidato.
      portraitColor: {r: 0.4, g: 0.9, b: 0.95, a: 1}
      blipPitch: 1.45
    fadeWhiteOut: 0
  - panelName: Aliens - oferta
    sceneRoot: {fileID: 1735236182}
    lines:
    - speakerName: ???
      text: "Voc\xEA n\xE3o \xE9 um homem mau. Apenas trope\xE7ou nas piores horas."
      portraitColor: {r: 0.4, g: 0.9, b: 0.95, a: 1}
      blipPitch: 1.45
    - speakerName: ???
      text: "Aceita voltar quatro vezes \u2014 e ajudar a si mesmo a atravess\xE1-las?"
      portraitColor: {r: 0.4, g: 0.9, b: 0.95, a: 1}
      blipPitch: 1.45
    - speakerName: Woody
      text: ...quatro vezes.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    fadeWhiteOut: 0
  - panelName: Relogio
    sceneRoot: {fileID: 454245919}
    lines:
    - speakerName: Woody
      text: Ok. De novo.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    - speakerName: Woody
      text: A gente acerta dessa vez.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    fadeWhiteOut: 0
  nextSceneName: Memory_01_Patio
  typewriter: {fileID: 556764864}
  speakerLabel: {fileID: 314306068}
  portrait: {fileID: 1847219052}
  dialogueBox: {fileID: 1452640698}
  continueIndicator: {fileID: 194161690}
  fader: {fileID: 613096158}
  panelFadeDuration: 0.6
  openingFadeDuration: 0.8
