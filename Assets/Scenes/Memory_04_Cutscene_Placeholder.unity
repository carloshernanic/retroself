--- !u!114 &1943393526
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1943393525}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9f64ff45bd52b63489bbae7d7d579685, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CutsceneController
  panels:
  - panelName: Reconhecimento
    sceneRoot: {fileID: 654603675}
    lines:
    - speakerName: Woody
      text: Demorei muito pra entender uma coisa simples.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    fadeWhiteOut: 0
  - panelName: Espelho
    sceneRoot: {fileID: 49590668}
    lines:
    - speakerName: Woody
      text: "Aquele menino que eu via no espelho \u2014 sozinho, com medo, sem entender
        \u2014"
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    - speakerName: Woody
      text: nao tinha pra onde correr.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    fadeWhiteOut: 0
  - panelName: Briga
    sceneRoot: {fileID: 1363244388}
    lines:
    - speakerName: Woody
      text: Por muito tempo eu briguei com ele.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    - speakerName: Woody
      text: Como se a culpa fosse dele por nao saber o que fazer.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    fadeWhiteOut: 0
  - panelName: Crianca
    sceneRoot: {fileID: 1507071582}
    lines:
    - speakerName: Woody
      text: Mas ele era so uma crianca.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    - speakerName: Woody
      text: E ninguem escolhe os domingos que herda.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    fadeWhiteOut: 0
  - panelName: Suficiente
    sceneRoot: {fileID: 917411828}
    lines:
    - speakerName: Woody
      text: Hoje eu congelo o tempo so por um instante.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    - speakerName: Woody
      text: Pra dizer que ele foi suficiente.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    - speakerName: Woody
      text: E que eu, finalmente, tambem sou.
      portraitColor: {r: 0.45, g: 0.32, b: 0.22, a: 1}
      blipPitch: 0.75
    fadeWhiteOut: 0
  nextSceneName: 
  OnFinished:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 1704894227}
        m_TargetAssemblyTypeName: CutsceneOutroSwitch, Assembly-CSharp
        m_MethodName: SwitchToCredits
        m_Mode: 0
